{
  "name": "camera-pip",
  "version": "1.5.2",
  "description": "Simple webcam PiP application for Windows",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --enable-logging",
    "build": "node build.js"
  },
  "keywords": [
    "electron",
    "webcam",
    "pip",
    "windows"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^26.8.1",
    "rcedit": "^5.0.2"
  },
  "dependencies": {
    "electron-store": "^10.1.0",
    "electron-window-state": "^5.0.3"
  },
  "build": {
    "appId": "com.camerapip.app",
    "productName": "Camera PiP",
    "directories": {
      "output": "dist"
    },
    "files": [
      "**/*"
    ],
    "win": {
      "target": "zip",
      "signAndEditExecutable": false,
      "icon": "icon.ico",
      "artifactName": "Camera-PiP-v${version}.${ext}"
    }
  }
}
